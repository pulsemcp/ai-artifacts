{
  "name": "trace-capture",
  "version": "1.0.0",
  "private": true,
  "description": "Hook for capturing agent session transcripts to cloud storage",
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "rebuild": "npm run clean && npm run build",
    "test": "vitest run",
    "test:e2e": "node test/e2e/hook-fires.mjs",
    "test:e2e:gcs": "node test/e2e/gcs-roundtrip.mjs",
    "test:all": "npm test && npm run test:e2e"
  },
  "devDependencies": {
    "@types/node": "~20.0.0",
    "typescript": "~5.5.0",
    "vitest": "^4.1.4"
  }
}
